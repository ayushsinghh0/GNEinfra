# Production env for the EC2 + Neon setup. Copy to the repo root as `.env` on the
# server and fill in real values. Never commit the real .env.

# ── Database: Neon (free tier). Use the connection string from the Neon console.
#    Keep ?sslmode=require. Prefer the region closest to the EC2 box (cross-region
#    adds ~90ms/query). The connection_limit/pool_timeout params bound how many
#    Postgres connections the app opens so a traffic burst can't exhaust Neon.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require&connection_limit=12&pool_timeout=20"

# ── Public URL (used in emailed links). MUST be a public HTTPS domain.
#    The app REFUSES to email links built on localhost, a bare IP, or a wildcard-DNS
#    host (sslip.io/nip.io) — they're unreachable for vendors and a heavy spam signal,
#    and a bare EC2 IP changes on every stop/start (attach an Elastic IP + real domain).
#    HTTPS is also required or the Secure admin login cookie is dropped by browsers.
APP_BASE_URL="https://vendors.YOURDOMAIN"

# ── Admin login (8+ chars or login is disabled).
ADMIN_PASSWORD="CHANGE-ME-strong-admin-password"

# ── Document storage: local disk on the box.
#    DOC_PURGE_DAYS  = delete a file this many days after its FIRST download.
#    DOC_MAX_AGE_DAYS = HARD cap: delete a file this many days after UPLOAD,
#      downloaded or not (bounds disk usage; whichever window hits first wins).
#      Set to "" / 0 to disable the hard cap. Enforced by the purge cron.
STORAGE_DRIVER="local"
DOC_PURGE_DAYS="7"
DOC_MAX_AGE_DAYS="3"
CRON_SECRET="CHANGE-ME-long-random-string"

# ── Email (SMTP). Example uses Gmail with an app password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user@gmail.com"
SMTP_PASS="your-app-password"
MAIL_FROM="GNE Procurement <your-smtp-user@gmail.com>"
PROCUREMENT_NOTIFY_EMAIL="your-smtp-user@gmail.com"
# Reply-To = a monitored human inbox (builds positive sending reputation). Keep the
# From on the Gmail address while relaying through smtp.gmail.com — a personal Gmail
# can't DKIM-sign your own domain, so a custom-domain From would FAIL DMARC alignment.
MAIL_REPLY_TO="your-smtp-user@gmail.com"

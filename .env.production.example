# ─────────────────────────────────────────────────────────────────────────
# GNE ERP — PRODUCTION env for the single-VPS Docker stack.
# On the server: copy to `.env`, fill in the values, then
#   docker compose -f docker-compose.prod.yml up -d --build
# Keep this file's real version (.env) secret — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────

# ── Domain / HTTPS ──
# Your hostname → Caddy gets a free HTTPS certificate automatically.
# Use ":80" instead if you only have an IP and want plain HTTP for now.
DOMAIN="vendors.yourdomain.com"
APP_BASE_URL="https://vendors.yourdomain.com"

# ── Database (Postgres runs in the same compose stack as service "db") ──
POSTGRES_PASSWORD="CHANGE-ME-strong-db-password"
DATABASE_URL="postgresql://gne:CHANGE-ME-strong-db-password@db:5432/gne_erp?schema=public"

# ── Document storage ──
# Local disk on the VPS (cheapest). Files auto-delete after DOC_PURGE_DAYS from
# first download, so disk usage stays tiny. No S3 needed.
STORAGE_DRIVER="local"
DOC_PURGE_DAYS="7"

# Secret protecting the purge endpoint (set a long random string).
CRON_SECRET="CHANGE-ME-long-random-string"

# ── Email (SMTP) ── use SES, Gmail/Workspace, Brevo, etc.
SMTP_HOST="email-smtp.ap-south-1.amazonaws.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
MAIL_FROM="GNE Procurement <procurement@yourdomain.com>"
PROCUREMENT_NOTIFY_EMAIL="procurement@yourdomain.com"

# ── Admin ──
ADMIN_PASSWORD="CHANGE-ME-strong-admin-password"

# ─────────────────────────────────────────────────────────────────────────
# GNE ERP — environment configuration
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
# ─────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────
# The ONLY thing you change to switch databases. Point it at any PostgreSQL.
#
# Local development (Docker, see docker-compose.yml — runs on port 5433):
DATABASE_URL="postgresql://gne:gne_local_dev@localhost:5433/gne_erp?schema=public"
#
# Production with Neon (https://neon.tech — free tier). After creating a
# project, copy the "Pooled connection" string and paste it here. Example:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/gne_erp?sslmode=require"

# ── Email (SMTP) ──────────────────────────────────────────────────────────
# Local development uses Mailpit (docker-compose) — no auth, view at :8025:
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
#
# Production example (e.g. Gmail / Google Workspace, or any provider):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="procurement@gne.example"
# SMTP_PASS="your-app-password"

# Address vendor-facing emails are sent FROM:
MAIL_FROM="GNE Procurement <procurement@gne.example>"

# Internal address(es) notified when a vendor submits (comma-separated):
PROCUREMENT_NOTIFY_EMAIL="procurement@gne.example"

# ── Document storage ──────────────────────────────────────────────────────
# "local" stores files on disk under ./uploads (development).
# "s3" stores them in Amazon S3 (or any S3-compatible store) for production.
STORAGE_DRIVER="local"

# Required when STORAGE_DRIVER="s3":
S3_BUCKET=""
AWS_REGION="ap-south-1"
# Leave these blank in real AWS and attach an IAM role instead (most secure).
# Set them for local MinIO testing or non-AWS hosting.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# For S3-compatible stores (e.g. local MinIO). Leave blank for real AWS S3.
S3_ENDPOINT=""
S3_FORCE_PATH_STYLE="false"

# Days after a file's FIRST download before it is automatically deleted from
# storage (major cost saving). The metadata record is kept.
DOC_PURGE_DAYS="7"

# ── Scheduled purge ───────────────────────────────────────────────────────
# Shared secret protecting /api/cron/purge. Generate a long random string.
# Call it on a daily schedule (see DEPLOY.md):
#   curl -X POST https://your-app/api/cron/purge -H "Authorization: Bearer <CRON_SECRET>"
CRON_SECRET="change-me-to-a-long-random-string"

# ── App ───────────────────────────────────────────────────────────────────
# Public base URL, used to build the registration links emailed to vendors.
APP_BASE_URL="http://localhost:3000"

# Simple shared password protecting the /admin panel in Phase 1.
# REQUIRED: set a strong value (8+ chars). Login is disabled until you do —
# there is no default password. Generate one with:  openssl rand -base64 18
ADMIN_PASSWORD=""

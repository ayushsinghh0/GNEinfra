// GNE ERP — Phase 1 data model (Vendor Registration).
//
// Designed to be the long-term foundation: later ERP modules (Procurement,
// Inventory, Project, Finance) will reference Vendor records by id / vendorCode.
// Evolve this schema with `npm run db:migrate` — every change is a tracked,
// reversible migration so existing vendor data is never lost.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Lifecycle of a vendor record, from invitation to approval.
enum VendorStatus {
  INVITED // invite emailed, form not yet submitted
  SUBMITTED // vendor completed the form
  UNDER_REVIEW // procurement is reviewing
  APPROVED // approved for use in the ERP (gets a vendorCode)
  REJECTED
}

enum InviteStatus {
  PENDING
  USED
  EXPIRED
  REVOKED
}

// A single vendor / supplier. Field names mirror the GNE Vendor Registration
// Form. Tax/registration numbers are optional except GST and PAN (mandatory),
// which is enforced at the application layer (see src/lib/validation.ts).
model Vendor {
  id     String       @id @default(cuid())
  status VendorStatus @default(SUBMITTED)

  // ERP vendor code, assigned on approval (e.g. "GNE-V-0001"). Unique when set.
  vendorCode String? @unique

  // ── Company information ──
  companyName       String
  contactPerson     String?
  mobileNumber      String?
  email             String
  address           String?
  state             String?
  website           String?
  dateOfIncorporation DateTime?
  yearsOfService    String?
  annualTurnover    String?

  // ── Statutory / tax registration ──
  gstNo         String // mandatory
  panNo         String // mandatory
  exciseNo      String?
  tinNo         String?
  vatLstNo      String?
  cstNo         String?
  serviceTaxNo  String?
  msmeNo        String?

  // ── Bank details (cancelled cheque uploaded as a VendorDocument) ──
  bankName          String?
  bankBranchAddress String?
  bankAccountNo     String?
  bankBranchCode    String?
  ifscCode          String?
  swiftCode         String? // required for foreign vendors
  ibanCode          String? // required for foreign suppliers

  // ── ERP posting classification (filled by GNE, not the vendor) ──
  genBusPostingGroup    String?
  exciseBusPostingGroup String?
  natureOfServices      String?
  vendorPostingGroup    String?

  // ── Relations ──
  projects    VendorProject[]
  documents   VendorDocument[]
  invite      VendorInvite?
  epcProjects Project[] @relation("VendorEpcProjects") // GNE projects where this vendor is the sub-partner

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyName])
  @@index([status])
  @@index([gstNo])
}

// Past projects the vendor has executed (the "Projects Details" sheet).
model VendorProject {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  serialNo           Int?
  clientName         String?
  capacity           String?
  projectType        String? // Solar / Wind
  contractType       String? // EPC / I&C / BOS
  location           String?
  yearOfCompletion   String?
  scopeOfWork        String?
  percentCompleted   String?
  remarks            String?

  @@index([vendorId])
}

// Files uploaded with a registration (cancelled cheque, GST cert, PAN, etc.).
// Stored gzip-compressed via the storage driver (local disk or S3); the
// storageKey locates the object. Files are purged a configurable number of days
// after their first download to minimise cloud storage cost — the metadata row
// is kept (purgedAt set) so we always know what was provided.
model VendorDocument {
  id       String @id @default(cuid())
  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  docType      String // e.g. CANCELLED_CHEQUE, GST_CERTIFICATE, PAN_CARD, OTHER
  originalName String
  storageKey   String // object key in the storage backend
  mimeType     String?
  originalSize Int? // bytes before compression
  storedSize   Int? // bytes actually stored
  compressed   Boolean @default(false)

  uploadedAt       DateTime  @default(now())
  downloadCount    Int       @default(0)
  firstDownloadedAt DateTime?
  purgeAfter       DateTime? // set on first download; file deleted after this
  purgedAt         DateTime? // when the file was actually deleted from storage

  @@index([vendorId])
  @@index([purgeAfter])
}

// An email invitation carrying a unique token. The vendor opens
// /register/<token> to fill the form. One invite may produce one vendor.
model VendorInvite {
  id        String       @id @default(cuid())
  email     String
  token     String       @unique
  status    InviteStatus @default(PENDING)
  companyHint String?    // optional company name typed by admin when inviting

  vendorId String? @unique
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  sentAt    DateTime  @default(now())
  expiresAt DateTime?
  usedAt    DateTime?

  @@index([email])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────
// PHASE 2 — Project Management
// Models the lifecycle of a GNE EPC solar project: scope (BOQ), execution
// (activities + daily progress), milestones, and material procurement (MRC).
// Mirrors the "Project Details & DPR" and "BOQ" workbooks.
// ─────────────────────────────────────────────────────────────────────────

enum ProjectStage {
  PLANNING
  ENGINEERING
  PROCUREMENT
  CONSTRUCTION
  TESTING
  COMMISSIONING
  LIVE
  HANDOVER
  CLOSED
}

model Project {
  id   String @id @default(cuid())
  gneId String @unique // e.g. GNEi-0001

  clientName    String? // BEL
  tenderId      String? // 569
  state         String? // MH
  cluster       String? // Shambhajinagar
  plantName     String? // Shivoor
  capacityAcMw  Float? // 13
  capacityDcMw  Float? // 16.9
  epcScope      String? // "EPC, Without PV"

  poNumber  String?
  poValueCr Float? // PO value in crores

  // The sub-partner executing the work (free text + optional link to a Vendor).
  subPartner String? // Datum / SES
  vendorId   String?
  vendor     Vendor? @relation("VendorEpcProjects", fields: [vendorId], references: [id])

  plantAddress  String?
  clientAddress String?

  stage        ProjectStage @default(PLANNING)
  startDate    DateTime?
  liveDate     DateTime?
  completeDate DateTime?
  handoverDate DateTime?

  blocks      ProjectBlock[]
  boqItems    BoqItem[]
  activities  ProjectActivity[]
  milestones  Milestone[]
  materials   ProcurementItem[]
  weatherLogs WeatherLog[]
  approvals   MaterialApproval[]
  safetyItems SafetyItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([clientName])
}

model ProjectBlock {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String // Block-1, Parcel-1

  activities ProjectActivity[]

  @@index([projectId])
}

enum BoqCategory {
  SUPPLY
  SERVICE
  LINE_WORK
}

// A scope / bill-of-quantities line item (from the BOQ workbook).
model BoqItem {
  id        String      @id @default(cuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category  BoqCategory @default(SUPPLY)

  section        String? // Modules, Inverters, MMS, Infrastructure Development...
  serialNo       String?
  description    String
  rating         String?
  specification  String?
  uom            String?
  quantity       Float?
  unitRate       Float? // optional cost per unit
  responsibility String? // who supplies/installs

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([category])
}

// An execution activity (from the DPR). Daily progress is recorded as DprEntry.
model ProjectActivity {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blockId   String?
  block     ProjectBlock? @relation(fields: [blockId], references: [id])

  activity    String // Topographical Survey
  subActivity String? // Topo survey, Bore Hole
  uom         String?
  totalQty    Float? // planned total
  startDate   DateTime?
  endDate     DateTime? // target completion

  entries DprEntry[]

  @@index([projectId])
}

// One day's progress against an activity (the daily columns in the DPR sheet).
model DprEntry {
  id         String          @id @default(cuid())
  activityId String
  activity   ProjectActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  date       DateTime
  qtyDone    Float
  note       String?

  createdAt DateTime @default(now())

  @@unique([activityId, date])
  @@index([activityId])
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model Milestone {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String // Topo, Land Grading, Commissioning, Plant Live date...
  category    String? // Engineering / Civil / Electrical / Testing
  plannedDate DateTime?
  actualDate  DateTime?
  status      MilestoneStatus @default(PENDING)
  sortOrder   Int             @default(0)

  @@index([projectId])
}

// Material procurement + receipt tracking (the "PO & MRC" sheet).
model ProcurementItem {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  partner         String? // Datum
  type            String? // BOS, Civil, Electrical
  description     String
  uom             String?
  approvedQty     Float?
  drawingApproved Boolean @default(false)
  poReleased      Boolean @default(false)
  receivedQty     Float?
  receivedDate    DateTime?
  qualitySignoff  Boolean @default(false)
  mrcStatus       String? // MRC done / WIP
  paymentStatus   String?
  remarks         String?

  createdAt DateTime @default(now())

  @@index([projectId])
}

enum RainIntensity {
  LIGHT
  MODERATE
  HEAVY
}

// Rain / weather day log (the "Rain" sheet) — impacts the construction schedule.
model WeatherLog {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  date         DateTime
  intensity    RainIntensity @default(MODERATE)
  fromTime     String? // "14:57"
  toTime       String? // "18:30"
  totalHours   Float? // hours lost
  daysImpacted Float? @default(1)
  note         String?

  createdAt DateTime @default(now())

  @@index([projectId])
}

// Approved-material delivery tracker per parcel/block (the "App materials" sheet).
model MaterialApproval {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parcel      String?
  block       String?
  item        String // IDT, Inverter, Modules...
  equipment   String? // rating, e.g. "4.5"
  capacityUom String? // MVA, MW
  uom         String? // Nos
  requiredQty Float?
  receivedQty Float?
  receivedAt  DateTime?
  note        String?

  createdAt DateTime @default(now())

  @@index([projectId])
}

// Site safety / PPE checklist item (the "PPE" sheet).
model SafetyItem {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  description String // Hard Hat, Safety Belts...
  unit        String? // Set
  qty         String? // "Each person", "5"
  available   Boolean @default(false)
  remarks     String?

  createdAt DateTime @default(now())

  @@index([projectId])
}
